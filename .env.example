# ScamShield Environment Variables

# Supabase (Required for production)
# Get these from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Database (Optional - for direct database access)
# DATABASE_URL="postgresql://username:password@localhost:5432/scamshield"

# AI Enhancement (Optional - for enhanced scam detection)
# Google AI (Gemini)
GOOGLE_AI_API_KEY="your-google-ai-api-key"
# Groq AI
GROQ_API_KEY="your-groq-api-key"
# Optional: OpenAI and Anthropic (legacy support)
# OPENAI_API_KEY="your-openai-api-key"
# ANTHROPIC_API_KEY="your-anthropic-api-key"

# Email Service (Optional - for notifications)
# RESEND_API_KEY="your-resend-api-key"
# FROM_EMAIL="noreply@scamshield.com"

# Analytics (Optional - for usage tracking)
# GOOGLE_ANALYTICS_ID="GA-XXXXXXXXX"
# POSTHOG_API_KEY="your-posthog-api-key"

# Rate Limiting (Optional - for API protection)
# UPSTASH_REDIS_REST_URL="your-upstash-redis-url"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# File Upload (Optional - for image storage)
# AWS_ACCESS_KEY_ID="your-aws-access-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET="scamshield-uploads"

# Development
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
